  "@type": "Dataset",
  "@id": "coloran-fl-slice-sla",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "name": "coloran-fl-slice-sla",
  "description": "Preprocessed substrate for a federated-learning cross-architecture benchmark on O-RAN slice SLA-violation prediction. Derived from the public Colosseum/ColO-RAN release (Polese et al., 2022). The unified parquet (18,352,874 rows) is keyed by (bs_id, slice_id, sched, tr): bs_id 1-7 are the seven gNBs used as the natural FL client partition, slice_id in {0,1,2} are the three network slices, sched in {0,1,2} the three MAC schedulers, and tr in {0..27} the 28 traffic-config indices. The out-of-distribution split is by tr: train tr in {0..21}, validation tr in {22..24}, test tr in {25..27}. Model inputs are 17 continuous KPI features (plus the 4 categorical keys above and 2 trend features computed at load time). The classification target y_sla_violation_next is derived 1 step ahead within each (run_id, slice_id) group as (ul_bler[t+1] > 0.10); the regression target y_tx_brate_dl_next is tx_brate_dl_Mbps[t+1]. Target derivation and leak-free scaling are implemented in src/fl_oran/data_v2/. The parquet itself is staged on Zenodo at camera-ready; it is regenerable from the upstream public dataset via the repository pipeline.",
  "license": "https://www.gnu.org/licenses/agpl-3.0.html",
  "url": "https://github.com/thc1006/fl-oran-tmc",
  "version": "0.9.4",
  "datePublished": "2026-05-21",
  "citeAs": "M. Polese et al., \"ColO-RAN: Developing Machine Learning-based xApps for Open RAN Closed-loop Control,\" IEEE Transactions on Mobile Computing, 2022. Preprocessing and FL benchmark: H.-C. Tsai, Federated O-RAN Slice SLA Prediction (2026), Zenodo DOI 10.5281/zenodo.20263144.",
  "creator": {
    "@type": "Person",
    "name": "Hsiu-Chi Tsai",
    "affiliation": "National Yang Ming Chiao Tung University",
    "url": "https://orcid.org/0000-0001-7421-8027"
  },
  "keywords": [
    "federated learning",
    "O-RAN",
    "network slicing",
    "SLA prediction",
    "Colosseum",
    "ColO-RAN"
  ],
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "coloran_raw_unified.parquet",
      "name": "coloran_raw_unified.parquet",
      "description": "Unified preprocessed parquet (18,352,874 rows) of the public Colosseum/ColO-RAN release. Archived under the concept DOI; the >=750 MiB parquet is staged at camera-ready and is regenerable from the upstream dataset via the repository pipeline. The sha256 below pins the exact preprocessed artifact used in the paper.",
      "contentUrl": "https://doi.org/10.5281/zenodo.20263144",
      "encodingFormat": "application/x-parquet",
      "sha256": "c674f28e75de78a861e945deefac73553a57fb3b538fa84f68d71179853d784c"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "records",
      "name": "records",
      "description": "Per-time-step cell/slice KPI records. Each record is one (bs_id, slice_id, sched, tr) state observation; rolling sequences of length 5 are constructed downstream for forecasting.",
      "key": { "@id": "records/bs_id" },
      "field": [
        { "@type": "cr:Field", "@id": "records/bs_id", "name": "bs_id", "description": "Base-station / gNB identifier (1-7). Used as the natural FL client partition (one gNB = one client).", "dataType": "sc:Integer", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "bs_id" } } },
        { "@type": "cr:Field", "@id": "records/slice_id", "name": "slice_id", "description": "Network slice identifier (0, 1, 2; three slices).", "dataType": "sc:Integer", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "slice_id" } } },
        { "@type": "cr:Field", "@id": "records/sched", "name": "sched", "description": "MAC scheduling policy (0, 1, 2; three schedulers).", "dataType": "sc:Integer", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "sched" } } },
        { "@type": "cr:Field", "@id": "records/tr", "name": "tr", "description": "Traffic-configuration index (0-27). OOD split key: train {0..21}, validation {22..24}, test {25..27}.", "dataType": "sc:Integer", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "tr" } } },
        { "@type": "cr:Field", "@id": "records/num_ues", "name": "num_ues", "description": "Number of connected UEs in the slice at time t.", "dataType": "sc:Integer", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "num_ues" } } },
        { "@type": "cr:Field", "@id": "records/slice_prb", "name": "slice_prb", "description": "PRBs allocated to the slice.", "dataType": "sc:Integer", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "slice_prb" } } },
        { "@type": "cr:Field", "@id": "records/sum_requested_prbs", "name": "sum_requested_prbs", "description": "Sum of requested PRBs.", "dataType": "sc:Integer", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "sum_requested_prbs" } } },
        { "@type": "cr:Field", "@id": "records/sum_granted_prbs", "name": "sum_granted_prbs", "description": "Sum of granted PRBs.", "dataType": "sc:Integer", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "sum_granted_prbs" } } },
        { "@type": "cr:Field", "@id": "records/tx_brate_dl_Mbps", "name": "tx_brate_dl_Mbps", "description": "Downlink transmit bitrate (Mbps).", "dataType": "sc:Float", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "tx_brate_dl_Mbps" } } },
        { "@type": "cr:Field", "@id": "records/rx_brate_ul_Mbps", "name": "rx_brate_ul_Mbps", "description": "Uplink receive bitrate (Mbps).", "dataType": "sc:Float", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "rx_brate_ul_Mbps" } } },
        { "@type": "cr:Field", "@id": "records/tx_pkts_dl", "name": "tx_pkts_dl", "description": "Downlink transmitted packets.", "dataType": "sc:Integer", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "tx_pkts_dl" } } },
        { "@type": "cr:Field", "@id": "records/rx_pkts_ul", "name": "rx_pkts_ul", "description": "Uplink received packets.", "dataType": "sc:Integer", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "rx_pkts_ul" } } },
        { "@type": "cr:Field", "@id": "records/dl_buffer_bytes", "name": "dl_buffer_bytes", "description": "Downlink buffer occupancy (bytes).", "dataType": "sc:Float", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "dl_buffer_bytes" } } },
        { "@type": "cr:Field", "@id": "records/ul_buffer_bytes", "name": "ul_buffer_bytes", "description": "Uplink buffer occupancy (bytes).", "dataType": "sc:Float", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "ul_buffer_bytes" } } },
        { "@type": "cr:Field", "@id": "records/dl_bler", "name": "dl_bler", "description": "Downlink block error rate.", "dataType": "sc:Float", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "dl_bler" } } },
        { "@type": "cr:Field", "@id": "records/ul_bler", "name": "ul_bler", "description": "Uplink block error rate. The 1-step-ahead value drives the SLA-violation target (ul_bler[t+1] > 0.10).", "dataType": "sc:Float", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "ul_bler" } } },
        { "@type": "cr:Field", "@id": "records/dl_mcs", "name": "dl_mcs", "description": "Downlink modulation and coding scheme index.", "dataType": "sc:Float", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "dl_mcs" } } },
        { "@type": "cr:Field", "@id": "records/ul_mcs", "name": "ul_mcs", "description": "Uplink modulation and coding scheme index.", "dataType": "sc:Float", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "ul_mcs" } } },
        { "@type": "cr:Field", "@id": "records/dl_cqi", "name": "dl_cqi", "description": "Downlink channel quality indicator.", "dataType": "sc:Float", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "dl_cqi" } } },
        { "@type": "cr:Field", "@id": "records/ul_sinr", "name": "ul_sinr", "description": "Uplink signal-to-interference-plus-noise ratio.", "dataType": "sc:Float", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "ul_sinr" } } },
        { "@type": "cr:Field", "@id": "records/ul_rssi", "name": "ul_rssi", "description": "Uplink received signal strength indicator.", "dataType": "sc:Float", "source": { "fileObject": { "@id": "coloran_raw_unified.parquet" }, "extract": { "column": "ul_rssi" } } }
      ]
    }
  ]
}
