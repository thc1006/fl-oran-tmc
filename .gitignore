# raw ColO-RAN dataset (8.9 GB, do not commit).
# No trailing slash — this path is a symlink in fl-oran-tmc, not a real directory,
# and gitignore patterns ending in '/' do not match symlinks.
raw

# processed parquet files (hundreds of MB) — same symlink caveat as raw above.
data
